# ============================================================
# NLU-EduPath Crawl System – Environment Variables
# Copy file này thành .env và điền giá trị thực
# ============================================================

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nlu_edupath
POSTGRES_USER=crawler
POSTGRES_PASSWORD=crawler_secret

# Full DSN (được tự động build từ các biến trên nếu để trống)
DATABASE_URL=postgresql://crawler:crawler_secret@localhost:5432/nlu_edupath

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# --- Scrapy ---
# Khoảng cách tối thiểu giữa 2 request (giây)
DOWNLOAD_DELAY=1.5
# Số request đồng thời tối đa
CONCURRENT_REQUESTS=8
CONCURRENT_REQUESTS_PER_DOMAIN=4

# --- Playwright ---
# headless=true để chạy không có giao diện (production)
# headless=false để debug (xem trình duyệt mở ra)
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_BROWSER_TYPE=chromium
# Timeout chờ element xuất hiện (ms)
PLAYWRIGHT_DEFAULT_TIMEOUT=15000

# --- Logging ---
LOG_LEVEL=INFO
# Thư mục chứa file log
LOG_DIR=logs

# --- Crawl behavior ---
# Năm bắt đầu thu thập điểm chuẩn
SCORE_YEAR_FROM=2020
# Năm kết thúc (thường là năm hiện tại)
SCORE_YEAR_TO=2025
# Số lần retry tối đa khi spider thất bại
MAX_RETRY=3

# --- Environment ---
# development | production
APP_ENV=development
